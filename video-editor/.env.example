# Required — server-side key for the Next.js → 21st SDK token exchange.
API_KEY_21ST=your_an_api_key_here

# ─────────────────────── Optional: production storage ───────────────────────
# If unset, renders are uploaded to catbox.moe (200 MB limit, anonymous, ok
# for demos). For anything real, create a public bucket named `video-renders`
# in your Supabase project and set these:
#
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_SERVICE_KEY=eyJ...          # service_role key, NOT anon
#   SUPABASE_VIDEO_BUCKET=video-renders  # optional, defaults to "video-renders"
#
# The sandbox reads these from its own env — set them via
#   npx @21st-sdk/cli env set video-editor SUPABASE_URL=... SUPABASE_SERVICE_KEY=...
# then redeploy.
