# 21st SDK credentials (https://21st.dev/agents/api-keys)
API_KEY_21ST=an_sk_your_key_here

# Convex database URL
# Run `npx convex dev` to get your deployment URL
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Same URL, used by the agent in the AN sandbox
# Set this in AN dashboard -> Environment Variables
CONVEX_URL=https://your-project.convex.cloud
